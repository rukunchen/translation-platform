# Supabase project URL. Used by browser and server clients.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable anon key. Safe for browser usage with RLS enabled.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase service role / secret key. Server only; never expose to the browser.
SUPABASE_SECRET_KEY=

# Public site URL used to generate invitation links. Required in production.
# Example: http://localhost:3000 locally or https://your-domain.example in production.
NEXT_PUBLIC_SITE_URL=

# Anthropic API key for Claude translation.
ANTHROPIC_API_KEY=

# DeepSeek API key for DeepSeek translation and glossary extraction.
DEEPSEEK_API_KEY=

# OpenAI API key for OpenAI translation provider.
OPENAI_API_KEY=

# Optional OpenAI-compatible base URL for proxy or compatible providers.
OPENAI_BASE_URL=

# Doubao / Volcengine Ark API key for Doubao translation provider.
DOUBAO_API_KEY=

# Optional alias used by Volcengine Ark official docs. Used when DOUBAO_API_KEY is empty.
ARK_API_KEY=

# Optional Doubao / Volcengine Ark OpenAI-compatible base URL.
DOUBAO_BASE_URL=

# Optional alias used when DOUBAO_BASE_URL is empty.
ARK_BASE_URL=

# Liveblocks secret key used by the server auth endpoint.
LIVEBLOCKS_SECRET_KEY=

# Liveblocks public key for browser-side Liveblocks clients.
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=

# Resend API key used to send project invitation emails.
RESEND_API_KEY=
